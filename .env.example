MAIN_URL=https://filmyfly.luxe/
PORT=3001
MAX_PAGES=1
INITIAL_PAGES=2

# Comma-separated keywords matched against scraped titles (case-insensitive)
HD_KEYWORDS=720p,1080p,HD,HDRip,WEB-DL,BluRay,Blu-Ray
K4_KEYWORDS=2160p,4k,4K,UHD

# Free key from https://www.themoviedb.org/settings/api (Developer plan)
TMDB_API_KEY=

# Server-side download folder (container path)
DOWNLOAD_DIR=/downloads

# Host folder mounted into Docker (used by docker-compose only)
DOWNLOAD_HOST_PATH=D:/HA/PlexMedia

# Emby library refresh (optional)
EMBY_URL=http://192.168.1.10:8096
EMBY_API_KEY=
# EMBY_PATH_PREFIX=/media/Plex_Media

# Redis listing cache (optional — speeds up dashboard loads)
# REDIS_URL=redis://default:password@host:6379
# CACHE_REFRESH_HOURS=4
